{
  "version": 1,
  "defaults": {
    "busyRetry": {
      "maxRetries": 2,
      "minDelay": "10s"
    },
    "backgroundQueue": {
      "cooldownAfterBusy": "30s"
    }
  },
  "profiles": {
    "standardText": {
      "description": "Execution policy for regular text-generation work. Model quota lives in modelCatalog/quotaManager.",
      "concurrency": 2
    },
    "singleLane": {
      "description": "Only one in-flight request at a time.",
      "concurrency": 1
    }
  },
  "sharedPools": {
    "speechSynthesis": {
      "description": "Shared active lane for all TTS tasks.",
      "limits": {
        "active": 1
      }
    }
  },
  "capabilities": {
    "textGeneration": {
      "general": {
        "use": ["standardText"]
      },
      "evaluation": {
        "use": ["standardText", "singleLane"]
      },
      "chat": {
        "use": ["standardText", "singleLane"]
      }
    },
    "speech": {
      "singleVoice": {
        "description": "Single-speaker TTS.",
        "concurrency": 2,
        "pool": "speechSynthesis"
      },
      "multiVoiceConversation": {
        "description": "Multi-speaker TTS.",
        "concurrency": 1,
        "pool": "speechSynthesis"
      },
      "transcription": {
        "description": "Speech-to-text requests.",
        "concurrency": 1
      }
    }
  }
}
