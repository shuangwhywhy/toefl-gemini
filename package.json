{
  "name": "toefl-gemini-tauri",
  "private": true,
  "version": "0.2.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "web:dev": "vite --host 0.0.0.0 --port 4173",
    "lint": "eslint . --max-warnings 0",
    "validate": "node scripts/validate.js",
    "build": "tsc && vite build",

    "web:build": "tsc && vite build",
    "preview": "vite preview",
    "web:preview": "vite preview --host 0.0.0.0 --port 4173",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage --coverage.include=src/** --coverage.thresholds.statements=75 --coverage.thresholds.branches=75 --coverage.thresholds.functions=75 --coverage.thresholds.lines=75",
    "test:watch": "vitest",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "ios:init": "tauri ios init --ci --skip-targets-install",
    "ios:dev": "dotenv -e .env -- tauri ios dev",
    "ios:build": "dotenv -e .env -- tauri ios build"
  },
  "dependencies": {
    "@google/genai": "^1.16.0",
    "@tauri-apps/api": "^2.8.0",
    "dexie": "^4.4.2",
    "lucide-react": "^0.544.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/line-clamp": "^0.4.4",
    "@tauri-apps/cli": "^2.8.0",
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^24.3.0",
    "@types/react": "^19.1.11",
    "@types/react-dom": "^19.1.7",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "@vitejs/plugin-react": "^5.0.2",
    "@vitest/coverage-v8": "3.2.4",
    "autoprefixer": "^10.4.21",
    "chalk": "^5.6.2",
    "dotenv-cli": "^11.0.0",
    "eslint": "^10.2.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "fake-indexeddb": "^6.2.5",
    "globals": "^17.5.0",
    "jsdom": "^26.1.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.59.0",
    "vite": "^7.1.3",
    "vitest": "^3.2.4"
  }
}
